definition
  mode BaseTwoHopModeAssertedHeadDef: BaseTwoHopModeAssertedHead is set;
end;

definition
  mode MiddleTwoHopModeAssertedHeadDef: MiddleTwoHopModeAssertedHead is BaseTwoHopModeAssertedHead;
end;

definition
  mode OuterTwoHopModeAssertedHeadDef: OuterTwoHopModeAssertedHead is MiddleTwoHopModeAssertedHead;
