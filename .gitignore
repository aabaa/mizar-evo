/doc/publications/**/*.log
/doc/publications/**/*.nav
/doc/publications/**/*.out
/doc/publications/**/*.snm
/doc/publications/**/*.toc
/doc/publications/**/*.vrb
/doc/publications/**/__pycache__/
/doc/publications/**/*.pyc
